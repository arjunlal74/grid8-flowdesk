generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Employee {
  id            Int       @id @default(autoincrement())
  fullName      String
  email         String    @unique
  passwordHash  String
  phone         String?
  role          Role      @default(MEMBER)
  designation   String?
  department    String?
  avatarUrl     String?
  isActive      Boolean   @default(true)
  joinedAt      DateTime  @default(now())
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  ownedLeads      Lead[]          @relation("LeadOwner")
  assignedTasks   Task[]          @relation("TaskAssignee")
  createdTasks    Task[]          @relation("TaskCreator")
  managedProjects Project[]       @relation("ProjectManager")
  projectMembers  ProjectMember[]
  activities      ActivityLog[]
  comments        Comment[]
}

enum Role {
  ADMIN
  MANAGER
  MEMBER
}

model Lead {
  id              Int        @id @default(autoincrement())
  contactName     String
  companyName     String?
  email           String?
  phone           String?
  whatsapp        String?
  website         String?
  city            String?
  state           String?
  country         String?    @default("India")
  categoryId      Int?
  category        LeadCategory? @relation(fields: [categoryId], references: [id])
  source          LeadSource @default(OTHER)
  sourceDetail    String?
  statusId        Int
  status          LeadStatus @relation(fields: [statusId], references: [id])
  priority        Priority   @default(MEDIUM)
  estimatedValue  Decimal?   @db.Decimal(12, 2)
  currency        String     @default("INR")
  expectedCloseAt DateTime?
  ownerId         Int?
  owner           Employee?  @relation("LeadOwner", fields: [ownerId], references: [id])
  description     String?    @db.Text
  position        Int        @default(0)
  isArchived      Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  lastContactedAt DateTime?

  tags        LeadTag[]
  activities  ActivityLog[]
  comments    Comment[]
  attachments Attachment[]
  tasks       Task[]
}

model LeadCategory {
  id        Int     @id @default(autoincrement())
  name      String  @unique
  slug      String  @unique
  parentId  Int?
  parent    LeadCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  LeadCategory[] @relation("CategoryHierarchy")
  color     String  @default("#A1A1A1")
  icon      String?
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())

  leads Lead[]
}

model LeadStatus {
  id        Int     @id @default(autoincrement())
  name      String  @unique
  slug      String  @unique
  color     String  @default("#60A5FA")
  order     Int     @default(0)
  isWon     Boolean @default(false)
  isLost    Boolean @default(false)
  isDefault Boolean @default(false)
  isActive  Boolean @default(true)

  leads Lead[]
}

enum LeadSource {
  REFERRAL
  COLD_CALL
  COLD_EMAIL
  WHATSAPP
  LINKEDIN
  INSTAGRAM
  WEBSITE
  EVENT
  WALK_IN
  OTHER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Tag {
  id    Int    @id @default(autoincrement())
  name  String @unique
  color String @default("#A1A1A1")
  leads LeadTag[]
}

model LeadTag {
  leadId Int
  tagId  Int
  lead   Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)
  @@id([leadId, tagId])
}

model Project {
  id          Int           @id @default(autoincrement())
  name        String
  slug        String        @unique
  code        String?       @unique
  description String?       @db.Text
  status      ProjectStatus @default(ACTIVE)
  color       String        @default("#FFFFFF")
  startDate   DateTime?
  endDate     DateTime?
  managerId   Int?
  manager     Employee?     @relation("ProjectManager", fields: [managerId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  members ProjectMember[]
  tasks   Task[]
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

model ProjectMember {
  projectId  Int
  employeeId Int
  role       String?
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  @@id([projectId, employeeId])
}

model Task {
  id             Int        @id @default(autoincrement())
  title          String
  description    String?    @db.Text
  statusId       Int
  status         TaskStatus @relation(fields: [statusId], references: [id])
  priority       Priority   @default(MEDIUM)
  projectId      Int?
  project        Project?   @relation(fields: [projectId], references: [id])
  leadId         Int?
  lead           Lead?      @relation(fields: [leadId], references: [id])
  assigneeId     Int?
  assignee       Employee?  @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creatorId      Int
  creator        Employee   @relation("TaskCreator", fields: [creatorId], references: [id])
  dueDate        DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  estimatedHours Decimal?   @db.Decimal(6, 2)
  actualHours    Decimal?   @db.Decimal(6, 2)
  position       Int        @default(0)
  parentTaskId   Int?
  parentTask     Task?      @relation("Subtasks", fields: [parentTaskId], references: [id])
  subtasks       Task[]     @relation("Subtasks")
  isArchived     Boolean    @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  activities  ActivityLog[]
  comments    Comment[]
  attachments Attachment[]
}

model TaskStatus {
  id        Int     @id @default(autoincrement())
  name      String  @unique
  slug      String  @unique
  color     String  @default("#A1A1A1")
  order     Int     @default(0)
  isDone    Boolean @default(false)
  isDefault Boolean @default(false)
  isActive  Boolean @default(true)

  tasks Task[]
}

model ActivityLog {
  id         Int      @id @default(autoincrement())
  actorId    Int
  actor      Employee @relation(fields: [actorId], references: [id])
  entityType String
  entityId   Int
  action     String
  changes    Json?
  createdAt  DateTime @default(now())
  leadId     Int?
  lead       Lead?    @relation(fields: [leadId], references: [id])
  taskId     Int?
  task       Task?    @relation(fields: [taskId], references: [id])

  @@index([entityType, entityId])
  @@index([createdAt])
}

model Comment {
  id        Int      @id @default(autoincrement())
  authorId  Int
  author    Employee @relation(fields: [authorId], references: [id])
  body      String   @db.Text
  leadId    Int?
  lead      Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  taskId    Int?
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Attachment {
  id           Int      @id @default(autoincrement())
  filename     String
  storedPath   String
  mimeType     String
  sizeBytes    Int
  uploadedById Int
  leadId       Int?
  lead         Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  taskId       Int?
  task         Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
}

model AppSetting {
  id              Int      @id @default(1)
  orgName         String   @default("Grid8")
  orgLogoUrl      String?
  defaultCurrency String   @default("INR")
  timezone        String   @default("Asia/Kolkata")
  updatedAt       DateTime @updatedAt
}
